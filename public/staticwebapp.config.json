{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/**", "/data/**", "/*.{png,jpg,gif,webp,svg,ico,json,geojson}"]
  },
  "globalHeaders": {
    "X-Frame-Options": "SAMEORIGIN",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "text/json",
    ".geojson": "application/geo+json"
  }
}
